# Python
# Byte-code files
__pycache__/
*.pyc
*.pyd
*.pyo
*.swp
.vscode/

# Distributions and packaging
.Python
build/
dist/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Omitted file, but generally not version controlled
.python-version # recommended to ignore this file

# IDEs and editors
.idea/  # popular for PyCharm projects
.vscode/ # popular for VS Code projects
.history/

# Testing and coverage
.pytest_cache/
.coverage
htmlcov/

# Transients
*.log
pip-log.txt
.tox/

# Specific directories and files often generated by tools
.ruff_cache/ # generated by ruff
.dccache/ # generated by Snyk

# Jupyter Notebook files
.ipynb_checkpoints
